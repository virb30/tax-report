{
  "name": "tax-report-backend",
  "version": "0.1.0",
  "description": "Tax Report web backend project shell",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "db:init": "ts-node src/app/infra/database/database-init.cli.ts",
    "dev": "ts-node src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "jest --coverage"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "better-sqlite3": "^12.6.2",
    "decimal.js": "^10.6.0",
    "express": "^5.2.1",
    "knex": "^3.1.0",
    "multer": "^2.1.1",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "eslint-plugin-jest": "^29.15.2",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "jest-mock-extended": "^4.0.1",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "24.15.0",
    "npm": ">=10"
  }
}
